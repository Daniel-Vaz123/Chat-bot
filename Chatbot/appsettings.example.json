{
  "Urls": "http://0.0.0.0:5000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AWS": {
    "Region": "us-east-1",
    "Profile": "default",
    "AccessKey": "YOUR_AWS_ACCESS_KEY_HERE",
    "SecretKey": "YOUR_AWS_SECRET_KEY_HERE"
  },
  "S3Vectors": {
    "BucketName": "YOUR_S3_BUCKET_NAME_HERE",
    "IndexName": "YOUR_INDEX_NAME_HERE",
    "ImageIndexName": "YOUR_IMAGE_INDEX_NAME_HERE",
    "TextEmbeddingDimensions": 1024,
    "ImageEmbeddingDimensions": 1024,
    "MaxQueryDistance": 0.88
  },
  "DeepSeek": {
    "ApiKey": "YOUR_DEEPSEEK_API_KEY_HERE"
  },
  "Bedrock": {
    "TextEmbeddingModel": "amazon.titan-embed-text-v2:0",
    "ImageEmbeddingModel": "amazon.titan-embed-image-v1"
  },
  "Vosk": {
    "ModelPath": "vosk-model-es"
  }
}
